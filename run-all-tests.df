[ main ]
df.main()() = {
    [ toggle address catching ]
    df.copy(df.true)(df.catch_addresses)

    [ tell user all tests are running ]
    df.set("[%0a;%09;Running all tests!%0a;]%0a;%0a;")(message)
    df.print.buffer_as_string(message)()

    [ run all tests ]
    [ get json file ]
    df.set("./tests/tests.json")(file_path)
    df.file_to_buffer(file_path)(json)

    [ check if not found ]
    df.integer.within_range(df.constant.0, json:start, df.constant.0)(not_found, found)
    @json.check_exists not_found = {
        [ print error ]
        df.set("Json file could not be found.%0a;")(message)
        df.print.buffer_as_string(message)()

        [ exit all test running ]
        df.jump.bottom(not_found, @df.master_scope)()
    }

    [ compile json ]
    df.json.compile(json, df.false)(json_workspace)
    @json.check_valid json_workspace:error:occured = {
        [ print error header ]
        df.set("Json file could not be compiled.%0a;")(message)
        df.print.buffer_as_string(message)()

        [ print error ]
        df.error.print_if_occured(json_workspace:error)()

        [ exit all test running ]
        df.jump.bottom(not_found, @df.master_scope)()
    }

    [ get list header ]
    df.set("tests")(json_name.tests)
    df.json.traverse.retrieve_parsling.by_name(json_workspace:parslings:root, json_name.tests)(json_parsling.tests_header, found, not_found)
    @json.couldnt_find_tests_header not_found = {
        [ print error header ]
        df.set("The main array (%22;tests%22;) inside the main json test file could not be found.%0a;")(message)
        df.print.buffer_as_string(message)()

        [ DEBUG ]
        df.json.compile.print.parsling(json_workspace, json_parsling.tests_header, df.constant.0)()

        [ exit all test running ]
        df.jump.bottom(not_found, @df.master_scope)()
    }

    [ setup loop data ]
    df.json.traverse.calculate.parsling_list_metadata(json_parsling.tests_header)(current, parsling_byte_size, tests.count)
    df.integer.subtract(tests.count, df.constant.1)(tests.max_index)
    df.set("name")(test_name_json_name)
    df.set("files")(test_files_json_name)

    [ check for no tests ]
    df.integer.within_range(df.constant.0, tests.count, df.constant.0)(in_range, out_of_range)
    df.jump.bottom(in_range, @df.master_scope)()

    [ setup first test ]
    df.set(df.integer.0)(tests.index)

    [ run test loop ]
    @json.run_all_tests df.always = {
        [ check if should quit ]
        df.integer.within_range(df.constant.0, tests.index, tests.max_index)(in_range, out_of_range)
        df.jump.bottom(out_of_range, @json.run_all_tests)()

        [ get parsling ]
        df.json.traverse.retrieve_parsling.by_index(json_parsling.tests_header, tests.index)(test.parsling, found, not_found)

        [ print test name ]
        df.json.traverse.retrieve_parsling.by_name(test.parsling, test_name_json_name)(json_parsling.name, found, not_found)
        @json.run_all_tests.no_test_name not_found = {
            [ "name" not found ]
            df.set("The test: %22;")(message)
            df.print.buffer_as_string(message)()
            df.print.buffer_as_string(test_name_json_name)()
            df.set("%22; Had an invalid json setup. The name of the test was not found.%0a;")(message)
            df.print.buffer_as_string(message)()

            [ exit all test running ]
            df.jump.bottom(not_found, @df.master_scope)()
        }

        [ print test name ]
        df.set("-------------%0a;Running test: ")(message)
        df.print.buffer_as_string(message)()
        df.print.buffer_as_string(json_parsling.name:value.datum:raw)()
        df.set(":%0a;-------------%0a;")(message)
        df.print.buffer_as_string(message)()

        [ get files's json parsling & it's metadata ]
        df.json.traverse.retrieve_parsling.by_name(test.parsling, test_files_json_name)(json_parsling.files, found, not_found)
        df.json.traverse.calculate.parsling_list_metadata(json_parsling.files)(current, parsling_byte_size, test_files.count)

        [ check for no files ]
        df.integer.within_range(df.constant.0, test_files.count, df.constant.0)(no_files_present, files_present)
        @json.run_all_tests.no_files_to_test no_files_present = {
            [ "files" not found ]
            df.set("The test: %22;")(message)
            df.print.buffer_as_string(message)()
            df.print.buffer_as_string(test_name_json_name)()
            df.set("%22; Had an invalid json setup. There were no file paths listed to compile.%0a;")(message)
            df.print.buffer_as_string(message)()

            [ exit this test running ]
            df.jump(not_found, @json.next_test)()
        }

        [ open files list ]
        df.structure.byte_size(test_files_json_name)(buffer.byte_size)
        df.integer.multiply(test_files.count, buffer.byte_size)(increase)
        df.list.open(increase)(sources)

        [ setup file index ]
        df.copy(df.constant.0)(test_files.index)
        df.integer.subtract(test_files.count, df.constant.1)(test_files.max_index)

        [ get sources ]
        @json.run_all_tests.get_test_files df.always = {
            [ check for end of loop ]
            df.integer.within_range(df.constant.0, test_files.index, test_files.max_index)(in_range, out_of_range)
            df.jump.bottom(out_of_range, @json.run_all_tests.get_test_files)()
            
            [ get file path from list ]
            df.json.traverse.retrieve_parsling.by_index(json_parsling.files, test_files.index)(test_file.parsling, found, not_found)
            df.buffer.trim_quotes(test_file.parsling:value.datum:raw)(file_path_string)

            [ load file into buffer ]
            df.file_to_buffer(file_path_string)(user_code_file)

            [ load user code to list ]
            df.list.append.buffer(sources, user_code_file)(sources)

            [ next file ]
            df.integer.add(test_files.index, df.constant.1)(test_files.index)
            df.jump.top(df.always, @json.run_all_tests.get_test_files)()
        }

        [ run test ]
        df.pack.null()(program.input !df.buffer)
        df.just_run(sources, program.input)(compilation.error, program.result, program.error)

        [ print compilation error if occured ]
        df.error.print_if_occured(compilation.error)()

        [ next test ]
        @json.next_test
        df.integer.add(tests.index, df.constant.1)(tests.index)
        df.jump.top(df.always, @json.run_all_tests)()
    }
}
